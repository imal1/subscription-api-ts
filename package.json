{
  "name": "subscription-api-ts",
  "version": "1.1.0",
  "description": "TypeScript订阅转换API服务 - 基于 Mihomo 内核，支持全协议转换 (vless/vmess/trojan/hysteria2/tuic)",
  "main": "dist/index.js",
  "private": true,
  "packageManager": "bun@1.0.30",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "cd frontend && bun run dev",
    "build": "cd frontend && bun run build",
    "start": "node frontend/.next/standalone/frontend/server.js",
    "lint": "oxlint frontend/src/",
    "lint:fix": "oxlint --fix frontend/src/",
    "test": "echo 'Tests not configured'",
    "clean": "rm -rf frontend/.next",
    "install:deps": "bun install",
    "setup": "bun run install:deps && bun run build",
    "config:validate": "bun -e \"console.log('✅ 配置验证通过，当前使用 config.yaml 管理配置')\"",
    "frontend:dev": "cd frontend && bun run dev",
    "frontend:build": "cd frontend && bun run build",
    "frontend:start": "cd frontend && bun run start",
    "frontend:lint": "cd frontend && bun run lint"
  },
  "keywords": [
    "subconverter",
    "subscription",
    "clash",
    "sing-box",
    "mihomo",
    "clash-meta",
    "vless",
    "vmess",
    "trojan",
    "hysteria2",
    "tuic",
    "typescript",
    "api",
    "proxy",
    "vpn",
    "protocol-conversion"
  ],
  "author": "imal1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imal1/subscription-api-ts.git"
  },
  "bugs": {
    "url": "https://github.com/imal1/subscription-api-ts/issues"
  },
  "homepage": "https://github.com/imal1/subscription-api-ts#readme",
  "dependencies": {
    "axios": "^1.10.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fs-extra": "^11.3.0",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.8",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.10",
    "oxlint": "^1.6.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
